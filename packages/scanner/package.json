  "keywords": [
    "ai",
    "agents",
    "agents-md",
    "claude-md",
    "gemini-md",
    "copilot-instructions",
    "prompt-governance",
    "policy-engine",
    "repository-scanner",
    "scanner",
    "typescript",
    "directiveops"
  ],
  "homepage": "https://www.directiveops.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pithpusher/DirectiveOps-Scanner.git"
  },
  "bugs": {
    "url": "https://github.com/pithpusher/DirectiveOps-Scanner/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/packages/scanner/src/index.js",
  "types": "dist/packages/scanner/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@directiveops/constitution-model": "0.1.0",
    "@directiveops/parser": "0.1.0",
    "@directiveops/policy-engine": "0.1.0",
    "@directiveops/oss-types": "0.1.0"
  }
}
